# ─── Arbeidskassen Environment Variables ─────────────────────────
# Copy this file to .env.local and fill in the values.

# ── Supabase (required for local dev) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # from `supabase status`
# Vercel uses NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY (alias for anon key)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — only needed for admin operations (webhooks, cron)
# SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (optional until billing is activated) ─────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Sentry (optional, error tracking) ───────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_AUTH_TOKEN=              # for source map uploads on deploy
# NEXT_PUBLIC_SENTRY_DSN=         # same DSN, exposed to client

# ── Rate Limiting (optional, Upstash Redis) ─────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
